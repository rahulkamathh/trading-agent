# ─────────────────────────────────────────────────────────────
#  Angel One SmartAPI credentials
#  Copy this file to .env and fill in your details.
#  NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# From https://smartapi.angelone.in → My Apps → Create App
ANGELONE_API_KEY=yJVBcN2u

# Your Angel One login ID (e.g. A123456)
ANGELONE_CLIENT_ID=AAAL951517

# Your Angel One login PIN / password
ANGELONE_PASSWORD=5252

# TOTP secret key — shown once when you enable 2FA in Angel One app settings
# (scan the QR code with your authenticator, then also note the text secret)
ANGELONE_TOTP_SECRET=FZQYP4QCMFL5YD2GMBPAOXMEBI

# ─────────────────────────────────────────────────────────────
#  Telegram Signal Intelligence
#  Get API ID + Hash from https://my.telegram.org/apps
#  (log in → "API development tools" → create an app)
# ─────────────────────────────────────────────────────────────

# Numeric app ID from my.telegram.org
TELEGRAM_API_ID=your_api_id_here

# 32-char hex hash from my.telegram.org
TELEGRAM_API_HASH=your_api_hash_here

# Your phone number with country code (used for one-time OTP on first run)
TELEGRAM_PHONE=+91xxxxxxxxxx
